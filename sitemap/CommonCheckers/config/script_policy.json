{
  "schema_version": 1,
  "policy_name": "common_script_policy",
  "allowed_categories": [
    "mobility",
    "scan"
  ],
  "allowed_actions_by_category": {
    "mobility": [
      "mobility.report.location",
      "mobility.move",
      "mobility.in2out",
      "mobility.out2in"
    ],
    "scan": [
      "scan.start",
      "scan.stop",
      "scan.once"
    ]
  },
  "blocked_actions_by_category": {
    "mobility": [
      "mobility.turn",
      "mobility.turn_move_turn.forward",
      "mobility.turn_move_turn.backward"
    ]
  },
  "allowed_scan_actions": [
    "scan.start",
    "scan.stop",
    "scan.once"
  ],
  "nonmoving_scan_actions": [
    "scan.start",
    "scan.stop",
    "scan.once"
  ],
  "allowed_mobility_actions": [
    "mobility.report.location",
    "mobility.move",
    "mobility.in2out",
    "mobility.out2in"
  ],
  "blocked_mobility_actions": [
    "mobility.turn",
    "mobility.turn_move_turn.forward",
    "mobility.turn_move_turn.backward"
  ],
  "moving_mobility_actions": [
    "mobility.move",
    "mobility.in2out",
    "mobility.out2in"
  ],
  "nonmoving_mobility_actions": [
    "mobility.report.location"
  ],
  "first_mobility_action_required": "mobility.report.location",
  "min_seconds_after_report_location_before_first_move": 60,
  "global_min_seconds_between_moving_mobility_commands": 180,
  "max_single_mobility_move_distance_m": 3.0
}
